{
  "name": "loom-harness",
  "version": "1.3.18",
  "private": true,
  "description": "Reusable agentic legacy-modernization harness: maps undocumented codebases, crawls running UIs, and rebuilds them pixel/function-faithful in modern stacks with A/B parity evals.",
  "license": "MIT",
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "test": "tsc -b && vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "docs": "typedoc"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "@types/node": "^22.15.0",
    "eslint": "^9.29.0",
    "prettier": "^3.5.3",
    "typedoc": "^0.28.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.0",
    "vitest": "^3.2.3"
  }
}
